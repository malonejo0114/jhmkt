QUEUE_PUBLISH_THREADS=q-publish-threads
QUEUE_PUBLISH_INSTAGRAM=q-publish-instagram
QUEUE_INSIGHTS=q-insights
QUEUE_IMPROVE=q-improve
QUEUE_TARGET_BASE_URL=http://localhost:8080

# Asset storage
STORAGE_MODE=local
LOCAL_ASSET_DIR=./.local_assets
GCS_BUCKET=

# External APIs (live mode)
