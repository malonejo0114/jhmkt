{
  "version": 2,
  "functions": {
    "api/index.py": {
      "regions": ["icn1"]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/cron/daily-bootstrap",
      "schedule": "5 15 * * *"
    },
    {
      "path": "/cron/dispatch/due",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/cron/improve/daily",
      "schedule": "40 16 * * *"
    },
    {
      "path": "/cron/improve/weekly",
      "schedule": "0 17 * * 0"
    },
    {
      "path": "/cron/engagement/process",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/cron/engagement/threads/process",
      "schedule": "*/15 * * * *"
    }
  ]
}
