COUPANG_BASE_URL=https://api-gateway.coupang.com
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Naver trend
NAVER_TREND_ENABLED=false
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
